---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ToolCard from "../components/ToolCard.astro";
const navLinks = [
  { label: "Magento", href: "/magento" },
  { label: "Shopware", href: "/shopware" },
  { label: "First CTO", href: "/first-cto" },
  { label: "Free tools", href: "/start" },
  { label: "Roles", href: "#roles" },
  { label: "Services", href: "#services" },
];
const diagnosticTools = [
  {
    title: "Hostage Check",
    question: "Are you really in control of your store?",
    effort: "12 questions · risk score",
    href: "/tools/hostage-check",
    accentColor: "#DC2626",
    accentColorDark: "#991B1B",
  },
  {
    title: "Speed Loss Calculator",
    question: "How much money is a slow site costing you?",
    effort: "instant estimate",
    href: "/tools/speed-loss",
    accentColor: "#F59E0B",
    accentColorDark: "#B45309",
  },
  {
    title: "AI Readiness Score",
    question: "Will an AI agent even find your store?",
    effort: "11 questions · 2 min",
    href: "/ai-readiness#score",
    accentColor: "#C026D3",
    accentColorDark: "#86198F",
  },
  {
    title: "Migration TCO",
    question: "Is it actually worth migrating to another platform?",
    effort: "instant estimate",
    href: "/tools/migration-tco",
    accentColor: "#6366F1",
    accentColorDark: "#4F46E5",
  },
];
const cards = [
  {
    href: "/magento",
    tag: "Magento · Adobe Commerce",
    title: "Magento CTO & Tech Lead",
    desc: "Certified Adobe Commerce engineers who take ownership of architecture, releases, upgrades and performance.",
    for: "For Magento / Adobe Commerce merchants",
    color: "#EE672F",
    dark: "#C94E1A",
  },
  {
    href: "/shopware",
    tag: "Shopware 6",
    title: "Shopware CTO & Tech Lead",
    desc: "Certified Shopware 6 engineers for architecture, releases, SW5→6 migrations and headless storefronts.",
    for: "For Shopware 6 stores",
    color: "#189EFF",
    dark: "#0E6DC2",
  },
  {
    href: "/first-cto",
    tag: "No IT department yet",
    title: "Your First CTO",
    desc: "A plain-language fractional CTO for merchants with no in-house IT — someone finally on your side of the table.",
    for: "For founders & non-technical owners",
    color: "#0F8C6C",
    dark: "#0B6B53",
  },
];
const serviceCards = [
  {
    href: "/tech-audit",
    tag: "Fixed price · €490",
    title: "E-commerce Tech Audit",
    desc: "A senior engineer reviews your entire store — code, infra, performance, security — and delivers a 40+ page report with a prioritized fix plan.",
    for: "For any platform · 10 business days",
    color: "#6C3AED",
    dark: "#5228BB",
  },
  {
    href: "/estimate-review",
    tag: "Fixed price · €290",
    title: "Agency Estimate Review",
    desc: "Send us your agency's quote. We tell you what's fair, what's inflated, and what's missing — with a push-back script you can use tomorrow.",
    for: "For merchants working with agencies",
    color: "#E6520F",
    dark: "#B8410C",
  },
  {
    href: "/speed-audit",
    tag: "Fixed price · €390",
    title: "Speed & Core Web Vitals Audit",
    desc: "We measure every critical page, calculate the revenue you're losing to slow load times, and rank fixes by ROI.",
    for: "For any platform · 7 business days",
    color: "#0891B2",
    dark: "#0E7490",
  },
  {
    href: "/due-diligence",
    tag: "M&A · PE · VC",
    title: "Technical Due Diligence",
    desc: "Independent assessment of an e-commerce asset's technology before acquisition — platform, team, debt, and hidden capex.",
    for: "For investors & acquirers",
    color: "#1E293B",
    dark: "#0F172A",
  },
  {
    href: "/migration-review",
    tag: "Open-Source vs SaaS",
    title: "Migration Review",
    desc: "An independent 3-year TCO and migration-risk verdict on replatforming — real numbers, what won't port, and a neutral recommendation.",
    for: "For merchants weighing a replatform",
    color: "#4F46E5",
    dark: "#3730A3",
  },
  {
    href: "/evacuation-plan",
    tag: "Fixed price · €350",
    title: "The Evacuation Plan",
    desc: "Independent code backup, restore-tested backups and a full access audit — so you can leave your agency without fear. We recover only what's yours.",
    for: "For merchants held hostage by an agency",
    color: "#DC2626",
    dark: "#991B1B",
  },
];
const roleCards = [
  {
    href: "/project-manager",
    tag: "Retainer · from 0.25 FTE",
    title: "Fractional Project Manager",
    desc: "Keeps your delivery on track — scope, timelines, agencies and risk. Turns a chaotic backlog into predictable releases.",
    for: "For teams that keep missing deadlines",
    color: "#D6336C",
    dark: "#A61E4D",
  },
  {
    href: "/business-analyst",
    tag: "Retainer · from 0.25 FTE",
    title: "Fractional Business Analyst",
    desc: "Turns vague ideas into buildable specs — requirements, process maps and acceptance criteria developers can build once.",
    for: "For teams plagued by rework",
    color: "#7048E8",
    dark: "#5125C7",
  },
  {
    href: "/product-manager",
    tag: "Retainer · from 0.25 FTE",
    title: "Fractional Product Manager",
    desc: "Owns the roadmap — discovery, prioritization and growth experiments tied to conversion, AOV and retention.",
    for: "For stores where growth has plateaued",
    color: "#0CA678",
    dark: "#087F5B",
  },
];
---
<Base
  title="CommerceLead — Outsourced CTO & Tech Leads for E-commerce"
  description="Certified Magento and Shopware developers, tech leads and fractional CTOs. Senior technical leadership without the full-time hire."
  accent="#14181D" accentDark="#000000" accentSoft="#EEF1EF" accentShadow="rgba(20,24,29,.14)">
  <Header links={navLinks} cta={{ label: "Choose your path", href: "#paths" }} />

  <main>
    <section class="hub-hero">
      <div class="wrap">
        <p class="eyebrow">Outsourced CTO &amp; Tech Lead for e-commerce</p>
        <h1>Senior technical leadership for your store — <em>without the full-time hire.</em></h1>
        <p class="lede">Certified Magento and Shopware engineers, hands-on tech leads, and fractional CTOs who take ownership of your platform. Pick the path that fits where you are today.</p>
        <div class="hero-meta">
          <span>Adobe &amp; Shopware certified</span>
          <span>From 0.5 FTE</span>
          <span>Audit to ownership in 2 weeks</span>
        </div>
      </div>
    </section>

    <section class="paths" id="paths">
      <div class="wrap">
        <div class="cards">
          {cards.map((c) => (
            <a class="card" href={c.href} style={`--c:${c.color};--cd:${c.dark};`}>
              <span class="tag">{c.tag}</span>
              <h2>{c.title}</h2>
              <p>{c.desc}</p>
              <span class="aud">{c.for}</span>
              <span class="go">Open →</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="diagnostics-section" id="diagnostics">
      <div class="wrap">
        <div class="section-head">
          <p class="eyebrow">Free diagnostics · No signup</p>
          <h2>Not sure where to start? Pick a free diagnostic.</h2>
          <p>Four instant tools for the most common headaches — no quiz-router, just pick the one that matches your problem.</p>
        </div>
        <div class="tool-card-grid">
          {diagnosticTools.map((t) => <ToolCard {...t} />)}
        </div>
        <p class="diagnostics-outro">
          <a class="btn--text" href="/start">See all diagnostics →</a>
        </p>
      </div>
    </section>

    <section class="services-section" id="roles">
      <div class="wrap">
        <div class="section-head">
          <p class="eyebrow">Fractional roles</p>
          <h2>The people who run delivery — from 0.25 FTE.</h2>
          <p>Not just engineers. The project, analysis, and product roles that turn effort into shipped, revenue-moving work.</p>
        </div>
        <div class="cards cards-3">
          {roleCards.map((c) => (
            <a class="card" href={c.href} style={`--c:${c.color};--cd:${c.dark};`}>
              <span class="tag">{c.tag}</span>
              <h2>{c.title}</h2>
              <p>{c.desc}</p>
              <span class="aud">{c.for}</span>
              <span class="go">Learn more →</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="services-section" id="services">
      <div class="wrap">
        <div class="section-head">
          <p class="eyebrow">Productized services</p>
          <h2>Fixed-price services — no proposal needed.</h2>
          <p>Clear scope, fixed price, guaranteed delivery. Pick what you need and order today.</p>
        </div>
        <div class="cards">
          {serviceCards.slice(0, 4).map((c) => (
            <a class="card" href={c.href} style={`--c:${c.color};--cd:${c.dark};`}>
              <span class="tag">{c.tag}</span>
              <h2>{c.title}</h2>
              <p>{c.desc}</p>
              <span class="aud">{c.for}</span>
              <span class="go">Learn more →</span>
            </a>
          ))}

          <a class="svc-feature" href="/ai-readiness" style="--c:#C026D3;--cd:#86198F;--cs:#FAE8FF;">
            <div class="svc-feature__main">
              <span class="tag">AI Readiness · new</span>
              <h2>Is your store ready for the AI era — and can AI agents even <em>find</em> you?</h2>
              <p>An honest, vendor-neutral score across 6 dimensions, then a fixed-scope audit and roadmap. No hype, no lock-in, measurable revenue. From €650.</p>
            </div>
            <div class="svc-feature__cta">
              <span class="svc-feature__btn">Take the free AI Readiness Score →</span>
              <span class="svc-feature__meta">2-minute quiz · instant score</span>
            </div>
          </a>

          {serviceCards.slice(4).map((c) => (
            <a class="card" href={c.href} style={`--c:${c.color};--cd:${c.dark};`}>
              <span class="tag">{c.tag}</span>
              <h2>{c.title}</h2>
              <p>{c.desc}</p>
              <span class="aud">{c.for}</span>
              <span class="go">Learn more →</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="tool-band">
      <div class="wrap tool-band__inner">
        <div>
          <p class="tool-band__eyebrow">Free interactive tool</p>
          <h2>How much is a <em>slow store</em> costing you?</h2>
          <p class="tool-band__lede">Plug in your revenue and load time and see the monthly &amp; yearly revenue you're leaking to slow pages — based on empirical Portent conversion data. No signup.</p>
          <div class="tool-band__meta">
            <span>Instant estimate</span>
            <span>Shareable report</span>
            <span>Built on real conversion research</span>
          </div>
        </div>
        <div class="tool-band__side">
          <a class="tool-band__btn" href="/tools/speed-loss">Open the speed calculator →</a>
          <span class="tool-band__note">Then turn the number into a fix plan.</span>
        </div>
      </div>
    </section>
  </main>

  <Footer
    tagline="fractional CTOs, certified developers &amp; fixed-price audits for e-commerce."
    mono="pick a path ↑" />

  <style>
    .hub-hero{padding:96px 0 60px;border-bottom:1px solid var(--line)}
    .hub-hero .eyebrow{font-family:'IBM Plex Mono',monospace;font-size:.78rem;letter-spacing:.12em;text-transform:uppercase;color:var(--slate);margin-bottom:20px}
    .hub-hero h1{font-family:'Archivo',sans-serif;font-weight:850;font-stretch:90%;font-size:clamp(2.3rem,4.4vw,3.5rem);line-height:1.05;letter-spacing:-.025em;margin-bottom:20px;max-width:18ch}
    .hub-hero h1 em{font-style:normal;color:var(--slate)}
    .hub-hero .lede{font-size:1.16rem;color:var(--slate);max-width:40em;margin-bottom:30px}
    .hub-hero .hero-meta{font-family:'IBM Plex Mono',monospace;font-size:.8rem;color:var(--slate);display:flex;gap:22px;flex-wrap:wrap}
    .hub-hero .hero-meta span::before{content:"▸ ";color:var(--ink)}

    .paths{padding:70px 0 100px}
    .cards{display:grid;grid-template-columns:repeat(3,1fr);gap:22px}
    .card{position:relative;display:flex;flex-direction:column;gap:12px;text-decoration:none;
      color:inherit;background:var(--white);border:1px solid var(--line);
      border-top:4px solid var(--c);padding:32px 30px;
      transition:transform .2s, box-shadow .2s, border-color .2s;}
    .card:hover{transform:translateY(-4px);box-shadow:0 14px 30px -18px var(--c);border-color:var(--c)}
    .card .tag{font-family:'IBM Plex Mono',monospace;font-size:.72rem;letter-spacing:.1em;text-transform:uppercase;color:var(--cd)}
    .card h2{font-family:'Archivo',sans-serif;font-weight:750;font-size:1.4rem;letter-spacing:-.015em;line-height:1.1}
    .card p{font-size:.96rem;color:var(--slate);flex:1}
    .card .aud{font-size:.84rem;color:var(--ink);font-weight:600;border-top:1px solid var(--line);padding-top:14px}
    .card .go{font-family:'IBM Plex Mono',monospace;font-size:.85rem;font-weight:600;color:var(--cd)}
    .diagnostics-section{padding:70px 0 90px;border-top:1px solid var(--line)}
    .diagnostics-section .section-head{text-align:center;max-width:38em;margin:0 auto 40px}
    .diagnostics-section .eyebrow{font-family:'IBM Plex Mono',monospace;font-size:.78rem;letter-spacing:.12em;text-transform:uppercase;color:var(--slate);margin-bottom:12px}
    .diagnostics-section h2{font-family:'Archivo',sans-serif;font-weight:850;font-stretch:90%;font-size:clamp(1.6rem,3vw,2.2rem);line-height:1.1;letter-spacing:-.02em;margin-bottom:14px}
    .diagnostics-section .section-head p{font-size:1.05rem;color:var(--slate)}
    .diagnostics-outro{text-align:center;margin-top:32px}
    .services-section{padding:0 0 100px;border-top:1px solid var(--line)}
    .services-section .section-head{text-align:center;max-width:38em;margin:70px auto 40px}
    .services-section .eyebrow{font-family:'IBM Plex Mono',monospace;font-size:.78rem;letter-spacing:.12em;text-transform:uppercase;color:var(--slate);margin-bottom:12px}
    .services-section h2{font-family:'Archivo',sans-serif;font-weight:850;font-stretch:90%;font-size:clamp(1.6rem,3vw,2.2rem);line-height:1.1;letter-spacing:-.02em;margin-bottom:14px}
    .services-section .section-head p{font-size:1.05rem;color:var(--slate)}
    .services-section .cards{grid-template-columns:repeat(2,1fr)}
    .services-section .cards.cards-3{grid-template-columns:repeat(3,1fr)}

    /* full-width feature banner (AI Readiness) */
    .svc-feature{grid-column:1 / -1;display:grid;grid-template-columns:1.7fr .8fr;gap:36px;align-items:center;
      text-decoration:none;color:inherit;background:var(--white);border:1px solid var(--line);
      border-top:4px solid var(--c);padding:40px 38px;box-shadow:16px 16px 0 0 var(--cs);
      transition:transform .2s, box-shadow .2s, border-color .2s;}
    .svc-feature:hover{transform:translateY(-4px);box-shadow:20px 20px 0 0 var(--cs);border-color:var(--c)}
    .svc-feature .tag{font-family:'IBM Plex Mono',monospace;font-size:.74rem;letter-spacing:.12em;text-transform:uppercase;color:var(--cd);display:block;margin-bottom:14px}
    .svc-feature h2{font-family:'Archivo',sans-serif;font-weight:850;font-stretch:92%;font-size:clamp(1.5rem,2.8vw,2.1rem);line-height:1.08;letter-spacing:-.02em;margin-bottom:14px}
    .svc-feature h2 em{font-style:normal;color:var(--c)}
    .svc-feature__main p{font-size:1.02rem;color:var(--slate);max-width:44ch}
    .svc-feature__cta{display:flex;flex-direction:column;gap:12px;align-items:flex-start}
    .svc-feature__btn{display:inline-block;background:transparent;border:1px solid var(--c);color:var(--cd);
      font-family:'IBM Plex Mono',monospace;font-size:.92rem;font-weight:500;padding:14px 25px;transition:background .15s,color .15s;}
    .svc-feature:hover .svc-feature__btn{background:var(--c);color:#fff}
    .svc-feature__meta{font-family:'IBM Plex Mono',monospace;font-size:.76rem;color:var(--slate)}
    @media(max-width:820px){.svc-feature{grid-template-columns:1fr;gap:22px;padding:32px 26px;box-shadow:10px 10px 0 0 var(--cs)}}
    @media(max-width:820px){.cards{grid-template-columns:1fr}.hub-hero{padding:64px 0 48px}.paths{padding:48px 0 64px}.services-section{padding:0 0 64px}}
  </style>
</Base>
