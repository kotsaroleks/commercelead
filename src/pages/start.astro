---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ContactForm from "../components/ContactForm.astro";
import ToolCard from "../components/ToolCard.astro";
const navLinks = [{ label: "The 4 tools", href: "#tools" }];
const tools = [
  {
    title: "Hostage Check",
    question: "Are you really in control of your store?",
    effort: "12 questions · risk score",
    href: "/tools/hostage-check",
    accentColor: "#DC2626",
    accentColorDark: "#991B1B",
  },
  {
    title: "Speed Loss Calculator",
    question: "How much money is a slow site costing you?",
    effort: "instant estimate",
    href: "/tools/speed-loss",
    accentColor: "#F59E0B",
    accentColorDark: "#B45309",
  },
  {
    title: "AI Readiness Score",
    question: "Will an AI agent even find your store?",
    effort: "11 questions · 2 min",
    href: "/ai-readiness#score",
    accentColor: "#C026D3",
    accentColorDark: "#86198F",
  },
  {
    title: "Migration TCO",
    question: "Is it actually worth migrating to another platform?",
    effort: "instant estimate",
    href: "/tools/migration-tco",
    accentColor: "#6366F1",
    accentColorDark: "#4F46E5",
  },
];
---
<Base
  title="4 Free E-commerce Diagnostics — No Signup | CommerceLead"
  description="Check your agency lock-in, your site speed losses, your AI readiness, or your migration math — 4 free, instant diagnostics for Magento & Shopware merchants. No signup required."
  accent="#14181D" accentDark="#000000" accentSoft="#EEF1EF" accentShadow="rgba(20,24,29,.14)">
  <Header links={navLinks} cta={{ label: "Book a free call", href: "#contact" }} />
  <main>

<section class="hub-hero">
  <div class="wrap">
    <p class="eyebrow">Free diagnostics · No signup</p>
    <h1>4 free diagnostics. <em>Pick your problem.</em></h1>
    <p class="lede">No quiz-router, no qualifying questions — just four instant tools for the most common headaches we hear from Magento and Shopware merchants. Each takes 2 minutes or less.</p>
  </div>
</section>

<section class="tools-section" id="tools">
  <div class="wrap">
    <div class="tool-card-grid">
      {tools.map((t) => <ToolCard {...t} />)}
    </div>

    <p class="tools-outro">
      Not sure which one fits? <a class="btn--text" href="#contact">Book a free call →</a>
    </p>
  </div>
</section>

<section class="cta" id="contact">
  <div class="wrap">
    <div class="cta-box">
      <div>
        <p class="eyebrow">Talk to a person instead</p>
        <h2>Skip the tools — get a free 45-minute call.</h2>
        <p>Tell us your store and your biggest technical headache. A senior engineer joins the call — no sales deck, no pressure.</p>
      </div>
      <ContactForm formName="start-contact" buttonLabel="Book my free call" note="No sales deck. A senior engineer joins the call." />
    </div>
  </div>
</section>

</main>
  <Footer tagline="4 free diagnostics for Magento &amp; Shopware merchants." mono="diagnose:pick --tool=any" />

  <style>
    .hub-hero{padding:96px 0 60px;border-bottom:1px solid var(--line)}
    .hub-hero .eyebrow{font-family:'IBM Plex Mono',monospace;font-size:.78rem;letter-spacing:.12em;text-transform:uppercase;color:var(--slate);margin-bottom:20px}
    .hub-hero h1{font-family:'Archivo',sans-serif;font-weight:850;font-stretch:90%;font-size:clamp(2.2rem,4.2vw,3.2rem);line-height:1.05;letter-spacing:-.025em;margin-bottom:20px;max-width:20ch}
    .hub-hero h1 em{font-style:normal;color:var(--slate)}
    .hub-hero .lede{font-size:1.1rem;color:var(--slate);max-width:38em}

    .tools-section{padding:70px 0 40px}
    .tools-outro{text-align:center;margin-top:36px;font-size:1rem;color:var(--slate)}
    .tools-outro .btn--text{margin-left:4px}

    .cta{padding:60px 0 100px}
    @media(max-width:820px){.hub-hero{padding:64px 0 48px}.tools-section{padding:48px 0 30px}}
  </style>
</Base>
